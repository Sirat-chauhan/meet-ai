APP_NAME=Meet AI
APP_ENV=development
SECRET_KEY=replace-this-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=120

DATABASE_URL=sqlite:///./ai_meeting_v2.db

# Supabase Auth (optional, recommended for production auth)
SUPABASE_URL=
SUPABASE_ANON_KEY=

# AI (optional)
# If empty, the app runs in local fallback mode (no paid LLM calls).
OPENAI_API_KEY=

# Optional: use an OpenAI-compatible provider (OpenRouter, Groq, Together, local, etc.)
# Examples:
#   OPENAI_BASE_URL=https://openrouter.ai/api/v1
#   OPENAI_BASE_URL=https://api.groq.com/openai/v1
OPENAI_BASE_URL=

# Optional: JSON object string forwarded as default headers to the OpenAI SDK.
# OpenRouter example:
#   OPENAI_DEFAULT_HEADERS_JSON={"HTTP-Referer":"http://localhost:8001","X-Title":"Meet AI"}
OPENAI_DEFAULT_HEADERS_JSON=

# Models (provider-dependent)
OPENAI_CHAT_MODEL=gpt-4o-mini
